# Binary files — never apply EOL conversion (avoids PDF/image corruption)
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.7z   binary
*.apk  binary
*.ipa  binary
*.mp4  binary
*.mp3  binary

# Text files — normalize line endings to LF in the repo
*.md      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.py      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.txt     text eol=lf
*.xml     text eol=lf
*.svg     text eol=lf
